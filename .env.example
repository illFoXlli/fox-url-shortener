# Project identity
APP_NAME=url-shortener
APP_IMAGE=url-shortener:latest
SPRING_PROFILES_ACTIVE=dev

# Common Spring settings
JPA_DDL_AUTO=validate
JPA_OPEN_IN_VIEW=false
FLYWAY_ENABLED=true
JACKSON_DEFAULT_PROPERTY_INCLUSION=non_null
SERVER_FORWARD_HEADERS_STRATEGY=framework
SPRINGDOC_API_DOCS_PATH=/v3/api-docs
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui

# Common application settings
SHORT_LINK_CODE_MIN_LENGTH=6
SHORT_LINK_CODE_MAX_LENGTH=8
SHORT_LINK_DEFAULT_EXPIRATION_DAYS=30
LOG_SECURITY_CONFIG_LEVEL=ERROR
LOG_SPRINGDOC_INITIALIZER_LEVEL=ERROR

# Dev Docker identity
DEV_APP_PROJECT_NAME=url-shortener-dev
DEV_APP_CONTAINER_NAME=url-shortener-dev
DEV_DB_PROJECT_NAME=postgres-infra-dev
DEV_DB_CONTAINER_NAME=postgres-server-dev
DEV_REDIS_PROJECT_NAME=redis-infra-dev
DEV_REDIS_CONTAINER_NAME=redis-server-dev

# Dev profile ports
DEV_APP_EXTERNAL_PORT=3396
DEV_APP_INTERNAL_PORT=3396

# Dev profile database
DEV_DB_HOST=localhost
DEV_DB_PORT=5433
DEV_DB_DOCKER_HOST=host.docker.internal
DEV_DB_NAME=url_shortener_dev
DEV_DB_USERNAME=admin
DEV_DB_PASSWORD=pass_admin
DEV_DB_IMAGE=postgres:17-alpine
DEV_DB_EXTERNAL_PORT=5433
DEV_DB_INTERNAL_HOST=db
DEV_DB_INTERNAL_PORT=5432

# Dev profile Redis
DEV_REDIS_HOST=localhost
DEV_REDIS_PORT=6380
DEV_REDIS_DOCKER_HOST=host.docker.internal
DEV_REDIS_USERNAME=fox
DEV_REDIS_PASSWORD=redis_dev_password
DEV_REDIS_IMAGE=redis:7-alpine
DEV_REDIS_EXTERNAL_PORT=6380
DEV_REDIS_INTERNAL_HOST=redis
DEV_REDIS_INTERNAL_PORT=6379
DEV_REDIS_MAXMEMORY=64mb
DEV_REDIS_MAXMEMORY_POLICY=allkeys-lru
DEV_REDIS_TIMEOUT=1s
DEV_REDIS_SSL_ENABLED=false
DEV_REDIRECT_CACHE_ENABLED=true
DEV_REDIRECT_CACHE_KEY_PREFIX=dev:fox-url-shortener:redirect:
DEV_REDIRECT_CACHE_TTL_SECONDS=300
DEV_REDIRECT_CACHE_CLICK_FLUSH_INTERVAL_MILLIS=10000

# Dev profile admin bootstrap
DEV_ADMIN_LOGIN=admin
DEV_ADMIN_PASSWORD=pass_admin
DEV_ADMIN_DISPLAY_NAME=ADMIN

# Dev profile JWT settings
DEV_JWT_SECRET=dev_jwt_secret_please_change_this_value_to_at_least_32_chars
DEV_JWT_ACCESS_EXPIRATION_MINUTES=15
DEV_JWT_REFRESH_EXPIRATION_DAYS=30

# Dev profile public URLs
DEV_APP_BASE_URL=http://localhost:3396
DEV_SHORT_URL_BASE_URL=http://localhost:3396

# Dev profile authentication cookies
DEV_COOKIE_ACCESS_TOKEN_NAME=access_token
DEV_COOKIE_REFRESH_TOKEN_NAME=refresh_token
DEV_COOKIE_SECURE=false
DEV_COOKIE_SAME_SITE=Lax
DEV_COOKIE_DOMAIN=

# Dev profile CORS
DEV_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3395,http://localhost:3396

# Dev profile reverse proxy headers
DEV_FORWARDED_PROTO_HEADER=X-Forwarded-Proto
DEV_FORWARDED_HOST_HEADER=X-Forwarded-Host
DEV_FORWARDED_PORT_HEADER=X-Forwarded-Port

# Prod Docker identity
PROD_APP_PROJECT_NAME=fox-url-shortener
PROD_APP_CONTAINER_NAME=fox-url-shortener
PROD_DB_PROJECT_NAME=postgres-infra
PROD_DB_CONTAINER_NAME=postgres-server
PROD_REDIS_PROJECT_NAME=redis-infra
PROD_REDIS_CONTAINER_NAME=redis-server

# Prod profile ports
PROD_APP_EXTERNAL_PORT=
PROD_APP_INTERNAL_PORT=

# Prod profile database
PROD_DB_HOST=
PROD_DB_PORT=
PROD_DB_DOCKER_HOST=postgres
PROD_DB_NAME=
PROD_DB_USERNAME=
PROD_DB_PASSWORD=
PROD_DB_IMAGE=postgres:16-alpine
PROD_DB_DATA_VOLUME=
PROD_DB_EXTERNAL_PORT=
PROD_DB_INTERNAL_HOST=
PROD_DB_INTERNAL_PORT=5432

# Prod profile Redis
PROD_REDIS_HOST=
PROD_REDIS_PORT=
PROD_REDIS_DOCKER_HOST=
PROD_REDIS_USERNAME=fox
PROD_REDIS_PASSWORD=
PROD_REDIS_IMAGE=redis:7-alpine
PROD_REDIS_EXTERNAL_PORT=
PROD_REDIS_INTERNAL_HOST=
PROD_REDIS_INTERNAL_PORT=6379
PROD_REDIS_MAXMEMORY=128mb
PROD_REDIS_MAXMEMORY_POLICY=allkeys-lru
PROD_REDIS_TIMEOUT=1s
PROD_REDIS_SSL_ENABLED=false
PROD_REDIRECT_CACHE_ENABLED=true
PROD_REDIRECT_CACHE_KEY_PREFIX=prod:fox-url-shortener:redirect:
PROD_REDIRECT_CACHE_TTL_SECONDS=300
PROD_REDIRECT_CACHE_CLICK_FLUSH_INTERVAL_MILLIS=10000

# Prod profile admin bootstrap
PROD_ADMIN_LOGIN=
PROD_ADMIN_PASSWORD=
PROD_ADMIN_DISPLAY_NAME=

# Prod profile JWT settings
PROD_JWT_SECRET=
PROD_JWT_ACCESS_EXPIRATION_MINUTES=15
PROD_JWT_REFRESH_EXPIRATION_DAYS=30

# Prod profile public URLs
PROD_APP_BASE_URL=
PROD_SHORT_URL_BASE_URL=

# Prod profile authentication cookies
PROD_COOKIE_ACCESS_TOKEN_NAME=access_token
PROD_COOKIE_REFRESH_TOKEN_NAME=refresh_token
PROD_COOKIE_SECURE=true
PROD_COOKIE_SAME_SITE=Lax
PROD_COOKIE_DOMAIN=

# Prod profile CORS
PROD_CORS_ALLOWED_ORIGINS=

# Prod profile reverse proxy headers
PROD_FORWARDED_PROTO_HEADER=X-Forwarded-Proto
PROD_FORWARDED_HOST_HEADER=X-Forwarded-Host
PROD_FORWARDED_PORT_HEADER=X-Forwarded-Port
